# ============================================================
# MCC Portfolio Platform — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# DO NOT commit the real .env file to version control.
# ============================================================

# PostgreSQL Database connection string
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/mcc_portfolio_db"

# JWT Auth secrets
JWT_KEY="YOUR_SUPER_SECRET_JWT_KEY"
JWT_ISSUER="MCCPortfolioAPI"
JWT_AUDIENCE="MCCPortfolioClient"

# SMTP / Email settings (e.g. Gmail App Password)
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_SENDER_NAME="MCC Placement Cell"
SMTP_SENDER_EMAIL="your-email@gmail.com"
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="YOUR_GMAIL_APP_PASSWORD"
